# Copy this file to .env and fill in real values.
# .env is already in .gitignore, never commit it.

# Server
PORT=4000

# JWT
# Used to sign demo login session tokens. For a demo, any long random string is fine.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Supabase (from your Supabase project settings -> API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# Demo accounts (MVP only has these two hardcoded users, no signup flow)
DEMO_USER_1_EMAIL=alex@demo.test
DEMO_USER_1_PASSWORD=demo1234
DEMO_USER_2_EMAIL=sam@demo.test
DEMO_USER_2_PASSWORD=demo1234
